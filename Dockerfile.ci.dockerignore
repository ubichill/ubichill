# Dockerfile.ci 専用の .dockerignore
# （通常の .dockerignore とは独立して機能する）
#
# Dockerfile.ci は CI がビルドした dist/ .next/ をそのまま COPY するため
# それらをここでは除外しない。

# ----------------------------------------
# 依存関係（最重量）
# ----------------------------------------
node_modules
packages/*/node_modules
plugins/*/node_modules
plugins/*/frontend/node_modules

# ----------------------------------------
# turbo キャッシュ
# ----------------------------------------
.turbo
packages/*/.turbo

# ----------------------------------------
# フロントエンド生成ファイル（styled-system はビルド成果物に含まれない）
# ----------------------------------------
packages/frontend/styled-system

# ----------------------------------------
# インフラ・設定（コンテナ内では不要）
# ----------------------------------------
charts/
worlds/
.github/
scripts/

# ----------------------------------------
# ドキュメント・エディタ設定
# ----------------------------------------
docs/
.vscode/
*.md
!packages/*/README.md

# ----------------------------------------
# Git
# ----------------------------------------
.git
.gitignore
