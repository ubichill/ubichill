{
  "id": "video-player",
  "name": "VideoPlayer",
  "version": "2.1.0",
  "entities": {
    "video-player:screen": {
      "capabilities": [
        "video:control",
        "scene:read",
        "scene:update",
        "net:broadcast"
      ],
      "mediaTargets": [
        "main"
      ],
      "watchEntityTypes": [
        "video-player:screen"
      ],
      "defaultTransform": {
        "x": 800,
        "y": 60,
        "z": 2,
        "w": 640,
        "h": 360
      },
      "dataFields": {
        "playlist": {
          "type": "json",
          "default": [],
          "label": "プレイリスト",
          "help": "{ id, title, mode: 'live' | 'video' } の配列"
        },
        "currentIndex": {
          "type": "number",
          "default": 0,
          "label": "再生中インデックス"
        },
        "isPlaying": {
          "type": "boolean",
          "default": false,
          "label": "再生中"
        },
        "currentTime": {
          "type": "number",
          "default": 0,
          "label": "現在時刻 (秒)"
        },
        "duration": {
          "type": "number",
          "default": 0,
          "label": "総再生時間 (秒)"
        },
        "loop": {
          "type": "enum",
          "default": "none",
          "options": [
            "none",
            "one",
            "all"
          ],
          "label": "ループ"
        },
        "shuffle": {
          "type": "boolean",
          "default": false,
          "label": "シャッフル"
        },
        "apiBase": {
          "type": "string",
          "default": "/plugins/video-player/api",
          "label": "API ベース URL"
        }
      },
      "workerUrl": "./screen/index.c3c3c599.js"
    },
    "video-player:controls": {
      "capabilities": [
        "ui:render",
        "net:fetch",
        "scene:read",
        "scene:update"
      ],
      "mediaTargets": [],
      "watchEntityTypes": [
        "video-player:screen"
      ],
      "defaultTransform": {
        "x": 800,
        "y": 800,
        "z": 200,
        "w": 740,
        "h": 100
      },
      "dataFields": {},
      "workerUrl": "./controls/index.86197a88.js"
    }
  }
}