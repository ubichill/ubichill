{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "WebWorker"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@ubichill/sdk": ["../../../packages/sdk/src/index.ts"],
            "@ubichill/sdk/*": ["../../../packages/sdk/src/*"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
