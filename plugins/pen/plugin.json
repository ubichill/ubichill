{
  "id": "pen",
  "name": "Pen",
  "version": "2.0.0",
  "components": {
    "canvas": {
      "src": "./src/canvas.worker.ts",
      "capabilities": ["scene:read", "scene:update", "ui:render", "net:broadcast", "canvas:draw"],
      "canvasTargets": ["drawing"],
      "watchEntityTypes": ["pen:stroke", "pen:pen"],
      "watchScope": "world",
      "defaultTransform": { "x": 0, "y": 0, "z": 5000 },
      "dataFields": {}
    },
    "tray": {
      "src": "./src/tray.worker.tsx",
      "capabilities": ["ui:render", "net:emit"],
      "defaultTransform": { "x": 20, "y": 20, "z": 1000, "w": 60, "h": 240 },
      "dataFields": {}
    },
    "pen": {
      "src": "./src/pen.worker.tsx",
      "capabilities": ["scene:read", "scene:update", "ui:render", "net:host-message", "net:emit"],
      "watchEntityTypes": ["pen:pen"],
      "watchScope": "entity",
      "defaultTransform": { "x": 0, "y": 0, "z": 1, "w": 36, "h": 48 },
      "dataFields": {
        "color": { "type": "color", "default": "#1a1a1a", "label": "ペンの色" },
        "strokeWidth": { "type": "number", "default": 4, "min": 1, "max": 30, "step": 1, "label": "線の太さ" }
      }
    },
    "stroke": {
      "dataFields": {}
    }
  }
}
