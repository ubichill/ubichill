{
  "id": "pen",
  "name": "Pen",
  "version": "2.0.0",
  "entities": {
    "pen:canvas": {
      "capabilities": [
        "scene:read",
        "scene:update",
        "ui:render",
        "net:broadcast",
        "canvas:draw"
      ],
      "canvasTargets": [
        "drawing"
      ],
      "watchEntityTypes": [
        "pen:stroke",
        "pen:pen"
      ],
      "defaultTransform": {
        "x": 0,
        "y": 0,
        "z": 5000
      },
      "dataFields": {},
      "workerUrl": "./canvas/index.1f0d3b8e.js"
    },
    "pen:tray": {
      "capabilities": [
        "scene:read",
        "scene:update",
        "ui:render",
        "net:host-message"
      ],
      "watchEntityTypes": [
        "pen:pen"
      ],
      "defaultTransform": {
        "x": 20,
        "y": 20,
        "z": 1000,
        "w": 60,
        "h": 240
      },
      "dataFields": {},
      "workerUrl": "./tray/index.9b6c752d.js"
    },
    "pen:pen": {
      "defaultTransform": {
        "x": 0,
        "y": 0,
        "z": 1
      },
      "dataFields": {
        "color": {
          "type": "color",
          "default": "#1a1a1a",
          "label": "ペンの色"
        },
        "strokeWidth": {
          "type": "number",
          "default": 4,
          "min": 1,
          "max": 30,
          "step": 1,
          "label": "線の太さ"
        }
      }
    }
  }
}