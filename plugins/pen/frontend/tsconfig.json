{
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@ubichill/sdk": [
                "../../../packages/sdk/src/index.ts"
            ],
            "@ubichill/sdk/react": [
                "../../../packages/sdk/src/react/index.ts"
            ],
            "@ubichill/engine": ["../../../packages/engine/src/index.ts"],
            "@ubichill/sandbox": ["../../../packages/sandbox/src/index.ts"],
            "@ubichill/sandbox/host": ["../../../packages/sandbox/src/host/index.ts"],
            "@ubichill/react": ["../../../packages/react/src/index.ts"],
            "@ubichill/shared": ["../../../packages/shared/src/index.ts"]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules"
    ]
}