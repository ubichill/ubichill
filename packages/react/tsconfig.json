{
  "compilerOptions": {
    "target": "ES2025",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "paths": {
      "@ubichill/engine": [
        "../engine/src/index.ts"
      ],
      "@ubichill/sandbox": [
        "../sandbox/src/index.ts"
      ],
      "@ubichill/shared": [
        "../shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
