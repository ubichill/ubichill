{
    "compilerOptions": {
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@styled-system/*": [
                "./styled-system/*"
            ],
            "@styles/*": [
                "./src/styles/*"
            ],
            "@/styled-system/*": [
                "./styled-system/*"
            ],
            "@ubichill/sdk": [
                "../sdk/src/index.ts"
            ],
            "@ubichill/sdk/react": [
                "../sdk/src/react/index.ts"
            ],
            "@ubichill/engine": ["../engine/src/index.ts"],
            "@ubichill/sandbox": ["../sandbox/src/index.ts"],
            "@ubichill/react": ["../react/src/index.ts"],
            "@ubichill/shared": ["../shared/src/index.ts"]
        },
        "target": "ESNext"
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
