{
  "compilerOptions": {
    "target": "ES2025",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@ubichill/engine": [
        "../engine/src/index.ts"
      ],
      "@ubichill/shared": [
        "../shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
