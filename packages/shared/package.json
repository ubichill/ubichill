{
    "name": "@ubichill/shared",
    "version": "1.0.0",
    "private": true,
    "description": "Shared types and constants for Ubichill",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./mod/vnode": {
            "types": "./dist/mod/vnode.d.ts",
            "import": "./dist/mod/vnode.js",
            "require": "./dist/mod/vnode.js"
        },
        "./mod/types": {
            "types": "./dist/mod/types.d.ts",
            "import": "./dist/mod/types.js",
            "require": "./dist/mod/types.js"
        }
    },
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec \"tsgo && node ../../scripts/touch.mjs dist/.build_done\"",
        "build": "tsgo",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "tsc-watch": "^7.2.0"
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}