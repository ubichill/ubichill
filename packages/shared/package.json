{
    "name": "@ubichill/shared",
    "version": "1.0.0",
    "private": true,
    "description": "Shared types and constants for Ubichill",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./plugin/vnode": {
            "types": "./dist/plugin/vnode.d.ts",
            "import": "./dist/plugin/vnode.js",
            "require": "./dist/plugin/vnode.js"
        },
        "./plugin/types": {
            "types": "./dist/plugin/types.d.ts",
            "import": "./dist/plugin/types.js",
            "require": "./dist/plugin/types.js"
        }
    },
    "scripts": {
        "dev": "tsc-watch --onSuccess \"node ../../scripts/touch.mjs dist/.build_done\"",
        "build": "tsc",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "tsc-watch": "^7.2.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}