# ----------------------------------------
# 依存関係・ビルドキャッシュ（最重量）
# ----------------------------------------
node_modules
packages/*/node_modules
mods/*/node_modules
mods/*/frontend/node_modules

# ----------------------------------------
# ビルド成果物（SKIP_BUILD=true 時は CI から受け取るため除外）
# ----------------------------------------
.next
packages/*/.next
dist
packages/*/dist

# ----------------------------------------
# turbo キャッシュ
# ----------------------------------------
.turbo
packages/*/.turbo

# ----------------------------------------
# フロントエンド生成ファイル（ビルド時に再生成される）
# ----------------------------------------
packages/frontend/styled-system

# ----------------------------------------
# インフラ・設定（コンテナ内では不要）
# ----------------------------------------
charts/
.github/

# ----------------------------------------
# ドキュメント・エディタ設定
# ----------------------------------------
docs/
.vscode/
*.md
!packages/*/README.md

# ----------------------------------------
# Git
# ----------------------------------------
.git
.gitignore

# mods/ は現状フロントエンドのワークスペースパッケージとして必須
# 将来的にプラグインを外部プラグインとして動的にするとき除外
# mods/
