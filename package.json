{
  "name": "ubichill",
  "version": "1.0.0",
  "private": true,
  "description": "2D metaverse-style work sharing web application",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "docker:up": "node scripts/start-plugins.mjs up -d",
    "docker:down": "node scripts/start-plugins.mjs down",
    "build:workers": "node scripts/build-workers.mjs",
    "build": "node scripts/build-workers.mjs && turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "pnpm --filter \"./packages/*\" clean",
    "test": "echo \"No tests specified yet\" && exit 0"
  },
  "volta": {
    "node": "25.9.0",
    "pnpm": "10.33.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/node": "^22.13.4",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "kill-port": "^2.0.1",
    "turbo": "^2.8.3"
  }
}